<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta http-equiv="X-UA-Compatible" content="IE=edge">
<title>{{ page_title }}{% if request.page_type == 'index' %} · Body Shaper Expert® · Loja oficial{% elsif page_title contains shop.name %}{% else %} · {{ shop.name }}{% endif %}</title>
{% render 'seo-meta' %}
<meta name="theme-color" content="#120D08">
<link rel="canonical" href="{{ canonical_url }}">
{%- assign idx_pages = 'index,product,collection,page,blog,article,list-collections' | split: ',' -%}
{%- if idx_pages contains request.page_type %}
<meta name="robots" content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1">
{%- endif %}
<link rel="icon" type="image/png" href="{{ 'favicon.png' | asset_url }}">
<link rel="apple-touch-icon" href="{{ 'apple-touch-icon.png' | asset_url }}">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="preload" as="font" type="font/woff" href="{{ 'butler-regular.woff' | asset_url }}" crossorigin>
{%- if request.page_type == 'index' %}
<link rel="preload" as="image" href="{{ 'hero-1-universo.webp' | asset_url }}" media="(min-width: 681px)" fetchpriority="high">
<link rel="preload" as="image" href="{{ 'm-universo.webp' | asset_url }}" media="(max-width: 680px)" fetchpriority="high">
{%- endif %}
{{ 'styles.css' | asset_url | stylesheet_tag }}
<script>
  (function(){ try{
    var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if(!reduce && document.visibilityState === 'visible'){ document.documentElement.classList.add('anim'); }
  }catch(e){} })();
</script>
{% render 'seo-schema' %}
{{ content_for_header }}
</head>
<body class="template-{{ request.page_type | handle }}">

<!-- ============ ANNOUNCEMENT ============ -->
<div class="ann">
  <div class="ann-track">
    <span>Portes grátis acima de €{{ settings.free_ship_threshold }} · {{ settings.free_ship_note }}</span><span>Entregas para toda a Europa</span><span>Pagamento seguro</span><span>Método Izabel de Paula®</span><span>Compre 2, ganhe brinde exclusivo</span>
    <span>Portes grátis acima de €{{ settings.free_ship_threshold }} · {{ settings.free_ship_note }}</span><span>Entregas para toda a Europa</span><span>Pagamento seguro</span><span>Método Izabel de Paula®</span><span>Compre 2, ganhe brinde exclusivo</span>
  </div>
</div>

<!-- ============ HEADER ============ -->
<header class="hdr">
  <div class="wrap">
    <a href="{{ routes.root_url }}" class="brand brand--logo" aria-label="Izabel de Paula — Body Shaper Expert">
      <img src="{{ 'logo-izb.png' | asset_url }}" alt="Izabel de Paula — Body Shaper Expert" class="brand-img" width="360" height="200">
    </a>
    <nav class="nav" aria-label="Navegação principal">
      <a href="{{ routes.root_url }}#bestsellers">Mais vendidos</a>
      <a href="{{ routes.all_products_collection_url }}">Loja</a>
      <a href="{{ routes.root_url }}#experiencia">Experiência</a>
      <a href="https://clinicaizabeldepaula.com/" target="_blank" rel="noopener">Clínica</a>
      <a href="https://formacoes.izabeldepaula.com/" target="_blank" rel="noopener">Formações</a>
    </nav>
    <div class="hdr-end">
      <a href="https://wa.me/{{ settings.whatsapp_number }}?text={{ 'Olá! Vim pelo site da Izabel de Paula e gostaria de saber mais sobre os vossos produtos.' | url_encode }}" class="icon-btn" aria-label="WhatsApp"><svg viewBox="0 0 24 24"><path d="M21 11.5a8.5 8.5 0 0 1-12.4 7.5L3 20l1.1-5.4A8.5 8.5 0 1 1 21 11.5Z"/></svg></a>
      <a href="{{ routes.cart_url }}" class="icon-btn" aria-label="Sacola" data-cart-open>
        <svg viewBox="0 0 24 24"><path d="M6 7h12l1 13H5L6 7Z"/><path d="M9 9V6a3 3 0 0 1 6 0v3"/></svg>
        <span class="cartn">{{ cart.item_count }}</span>
      </a>
      <button class="burger" aria-label="Menu"><span></span><span></span><span></span></button>
    </div>
  </div>
</header>

<nav class="drawer" aria-label="Menu">
  <div class="d-head">
    <a href="{{ routes.root_url }}" class="brand brand--logo d-brand" aria-label="Izabel de Paula — início"><img src="{{ 'logo-izb.png' | asset_url }}" alt="Izabel de Paula — Body Shaper Expert" class="brand-img" width="360" height="200"></a>
    <button class="d-close" type="button" data-drawer-close aria-label="Fechar menu"><svg viewBox="0 0 24 24"><path d="M6 6l12 12M18 6 6 18"/></svg></button>
  </div>
  <div class="d-nav">
    <a href="{{ routes.root_url }}#bestsellers">Mais vendidos</a>
    <a href="{{ routes.all_products_collection_url }}">Loja</a>
    <a href="{{ routes.root_url }}#experiencia">Experiência</a>
    <a href="https://clinicaizabeldepaula.com/" target="_blank" rel="noopener">Clínica</a>
    <a href="https://formacoes.izabeldepaula.com/" target="_blank" rel="noopener">Formações</a>
  </div>
  <div class="d-cta">
    <a href="{{ routes.all_products_collection_url }}" class="btn btn--bone">Ver a coleção</a>
    <a href="https://wa.me/{{ settings.whatsapp_number }}?text={{ 'Olá! Vim pelo site da Izabel de Paula e gostaria de saber mais sobre os vossos produtos.' | url_encode }}" class="btn btn--ghost">Falar no WhatsApp</a>
  </div>
</nav>

<main id="MainContent">
  {{ content_for_layout }}
</main>

{% section 'footer' %}

<!-- Portes / brinde -->
<div class="frete">
  <span class="x" role="button" aria-label="Fechar">×</span>
  <div class="top">
    <svg viewBox="0 0 24 24"><path d="M3 7h13v8H3z"/><path d="M16 10h3l2 3v2h-5z"/><circle cx="7" cy="17" r="1.6"/><circle cx="17" cy="17" r="1.6"/></svg>
    <p>Faltam <b>€{{ settings.free_ship_threshold }},00</b> para você ganhar <b>portes grátis</b>!</p>
  </div>
  <div class="bar"><i></i></div>
</div>

<!-- WhatsApp -->
<a href="https://wa.me/{{ settings.whatsapp_number }}?text={{ 'Olá! Vim pelo site da Izabel de Paula e gostaria de saber mais sobre os vossos produtos.' | url_encode }}" class="wa" aria-label="Falar no WhatsApp">
  <svg viewBox="0 0 24 24"><path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38a9.9 9.9 0 0 0 4.79 1.22h.01c5.46 0 9.91-4.45 9.91-9.91C21.96 6.45 17.5 2 12.04 2Zm5.8 14.2c-.24.68-1.4 1.3-1.94 1.34-.5.05-1.13.07-1.83-.11-.42-.13-.96-.31-1.65-.61-2.9-1.25-4.8-4.17-4.94-4.36-.15-.2-1.19-1.58-1.19-3.01 0-1.43.75-2.13 1.02-2.42.27-.29.58-.36.78-.36.2 0 .39 0 .56.01.18.01.42-.07.66.5.24.59.83 2.02.9 2.17.07.15.12.32.02.51-.1.2-.15.32-.29.49-.15.17-.31.39-.44.52-.15.15-.3.31-.13.6.17.29.76 1.25 1.63 2.02 1.12 1 2.06 1.31 2.35 1.46.29.15.46.12.63-.07.17-.2.73-.85.92-1.14.2-.29.39-.24.66-.15.27.1 1.7.8 1.99.95.29.15.48.22.55.34.07.12.07.71-.17 1.39Z"/></svg>
</a>

{%- comment -%}
  product-data emite inline window.SHOP/SHOPIFY_LIVE (corre no parse, antes dos
  defer). Os scripts externos usam `defer`: executam por ordem do documento após
  o parse do DOM (que é o que toda a lógica de render espera) e logo após os
  inline window.IZB_HANDLE / IZB_OPEN_CART injetados pelos templates.
{%- endcomment -%}
{% render 'product-data' %}
<script src="{{ 'theme-meta.js' | asset_url }}" defer></script>
<script src="{{ 'bootstrap.js' | asset_url }}" defer></script>
<script src="{{ 'cart.js' | asset_url }}" defer></script>
<script src="{{ 'proof.js' | asset_url }}" defer></script>
<script src="{{ 'content.js' | asset_url }}" defer></script>
<script src="{{ 'reviews.js' | asset_url }}" defer></script>
<script src="{{ 'product.js' | asset_url }}" defer></script>
<script src="{{ 'theme.js' | asset_url }}" defer></script>
</body>
</html>
