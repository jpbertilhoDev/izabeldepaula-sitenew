<section class="section"><div class="wrap">
  <div class="head-c" data-reveal><span class="kicker">Pesquisa</span><h1 class="h-sec">Pesquisar</h1></div>

  <form action="{{ routes.search_url }}" method="get" role="search" class="auth" style="margin-bottom:34px">
    <div class="field"><label for="q">O que procura?</label>
      <input type="search" id="q" name="q" value="{{ search.terms | escape }}" placeholder="Ex.: detox, creme, kit…"></div>
    <button type="submit" class="btn btn--ink">Pesquisar</button>
  </form>

  {%- if search.performed -%}
    {%- if search.results_count == 0 -%}
      <p style="text-align:center">Nenhum resultado para “{{ search.terms | escape }}”.</p>
    {%- else -%}
      <p class="alt" style="text-align:center;margin-bottom:20px">{{ search.results_count }} resultado(s) para “{{ search.terms | escape }}”.</p>
      <div class="grid">
        {%- for item in search.results -%}
          {%- if item.object_type == 'product' -%}
            <article class="pcard">
              <div class="media"><a href="{{ item.url }}"><img src="{{ item.featured_image | image_url: width: 600 }}" alt="{{ item.title | escape }}" loading="lazy" width="600" height="600"></a></div>
              <div class="body"><h3><a href="{{ item.url }}">{{ item.title }}</a></h3>
                <div class="foot"><div class="price"><span class="now">{{ item.price | money }}</span></div><a class="buy" href="{{ item.url }}">Ver</a></div></div>
            </article>
          {%- else -%}
            <article class="pcard"><div class="body"><h3><a href="{{ item.url }}">{{ item.title }}</a></h3>
              <p class="blurb">{{ item.content | default: item.excerpt | strip_html | truncatewords: 20 }}</p></div></article>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
  {%- endif -%}
</div></section>
