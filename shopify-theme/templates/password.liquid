<section class="section" style="min-height:78vh;display:flex;align-items:center;text-align:center">
  <div class="wrap auth">
    <img src="{{ 'logo-izb.png' | asset_url }}" alt="{{ shop.name }}" width="180" height="100" style="display:block;margin:0 auto 22px">
    <span class="kicker">Em breve</span>
    <h1 class="h-sec">Estamos a preparar <span class="it gold">algo especial.</span></h1>
    <p class="alt" style="margin:16px 0 26px">{{ shop.password_message | default: 'A nossa loja abre muito em breve. Volte daqui a pouco!' }}</p>
    {%- form 'storefront_password' -%}
      {%- if form.errors -%}<div class="errors">{{ form.errors | default_errors }}</div>{%- endif -%}
      <div class="field"><label for="store-pass">Senha da loja</label>
        <input type="password" id="store-pass" name="password" required></div>
      <button type="submit" class="btn btn--ink">Entrar</button>
    {%- endform -%}
    <p class="alt" style="margin-top:20px"><a href="https://wa.me/{{ settings.whatsapp_number }}">Falar connosco no WhatsApp</a></p>
  </div>
</section>
