<section class="section"><div class="wrap auth">
  <div class="head-c" data-reveal><span class="kicker">Conta</span><h1 class="h-sec">Repor a senha</h1></div>
  <p class="alt" style="margin-bottom:22px">Defina uma nova senha para a sua conta.</p>
  {%- form 'reset_customer_password' -%}
    {%- if form.errors -%}<div class="errors">{{ form.errors | default_errors }}</div>{%- endif -%}
    <div class="field"><label for="rst-pass">Nova senha</label>
      <input type="password" id="rst-pass" name="customer[password]" autocomplete="new-password" required></div>
    <div class="field"><label for="rst-conf">Confirmar senha</label>
      <input type="password" id="rst-conf" name="customer[password_confirmation]" autocomplete="new-password" required></div>
    <button type="submit" class="btn btn--ink">Guardar nova senha</button>
  {%- endform -%}
</div></section>
